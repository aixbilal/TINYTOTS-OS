/* =========================
   80mm Thermal Receipt
========================= */

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  background: #ffffff;
  color: #000;
  font-family: "Courier New", monospace;
}

/* ========================= */

