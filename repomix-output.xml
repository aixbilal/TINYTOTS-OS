                      }`}
                    >
                      {item.stock <= 0 && <AlertTriangle size={12} />}
                      {item.stock <= 0 ? "Out of stock" : `${item.stock} left`}
                    </span>
                  </td>
                  <td className="px-6 py-4 text-ink-700">
                    {item.supplierId || <span className="text-ink-400 italic">Not set</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}
