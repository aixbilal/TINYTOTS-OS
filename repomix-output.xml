CREATE FUNCTION public.deduct_stock()
 RETURNS trigger
 LANGUAGE plpgsql
AS $function$
BEGIN
    UPDATE variants
    SET
        stock = stock - NEW.quantity,
        is_low_stock = (stock - NEW.quantity) <= reorder_level
    WHERE id = NEW.variant_id;

    RETURN NEW;
END;
$function$;
