        document.addEventListener('DOMContentLoaded', () => {
            const phase1 = document.getElementById('phase-1');
            const phase2 = document.getElementById('phase-2');
            const phase3 = document.getElementById('phase-3');
            
            const btnNext1 = document.getElementById('btn-next-1');
            const btnNext2 = document.getElementById('btn-next-2');
            const btnBack = document.getElementById('btn-back');

            const progressBar = document.getElementById('progress-bar');
            const step1Ind = document.getElementById('step-1-indicator');
            const step2Ind = document.getElementById('step-2-indicator');
            const step3Ind = document.getElementById('step-3-indicator');

            let currentPhase = 1;

            function updateUI(phase) {
                // Update Phases
                [phase1, phase2, phase3].forEach((p, index) => {
                    if (index + 1 === phase) {
                        p.classList.remove('phase-hidden');
                        p.classList.add('phase-active');
                    } else {
                        p.classList.add('phase-hidden');
                        p.classList.remove('phase-active');
                    }
                });

                // Update Progress Bar
                if (phase === 1) progressBar.style.width = '0%';
                if (phase === 2) progressBar.style.width = '50%';
                if (phase === 3) progressBar.style.width = '100%';

                // Update Indicators
                if (phase >= 1) {
                    step1Ind.classList.add('bg-primary-container', 'text-on-primary');
                    step1Ind.classList.remove('bg-surface-variant', 'text-on-surface-variant');
                }
                if (phase >= 2) {
                    step2Ind.classList.add('bg-primary-container', 'text-on-primary');
                    step2Ind.classList.remove('bg-surface-variant', 'text-on-surface-variant');
                } else {
                    step2Ind.classList.remove('bg-primary-container', 'text-on-primary');
                    step2Ind.classList.add('bg-surface-variant', 'text-on-surface-variant');
                }
                if (phase >= 3) {
                    step3Ind.classList.add('bg-primary-container', 'text-on-primary');
                    step3Ind.classList.remove('bg-surface-variant', 'text-on-surface-variant');
                } else {
                    step3Ind.classList.remove('bg-primary-container', 'text-on-primary');
                    step3Ind.classList.add('bg-surface-variant', 'text-on-surface-variant');
                }
            }

            btnNext1.addEventListener('click', () => {
                currentPhase = 2;
                updateUI(currentPhase);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            btnNext2.addEventListener('click', () => {
                currentPhase = 3;
                updateUI(currentPhase);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            btnBack.addEventListener('click', () => {
                if (currentPhase > 1) {
                    currentPhase--;
                    updateUI(currentPhase);
                } else {
                    // Navigate back to previous page or home
                    console.log('Exit flow');
                }
            });
        });
    </script>
