            const item1Container = item1Check.closest('.bg-surface');

            const item2Check = document.getElementById('item-2');
            const reason2Select = document.getElementById('reason-2');
            const item2Container = item2Check.closest('.bg-surface');
            const item2Content = item2Container.querySelector('.flex-grow');
            const item2ReasonContainer = reason2Select.parentElement;

            function toggleItemState(checkbox, select, container, content, reasonContainer) {
                if (checkbox.checked) {
                    select.disabled = false;
                    content.classList.remove('opacity-70');
                    reasonContainer.classList.remove('opacity-50', 'pointer-events-none');
                    select.classList.remove('bg-surface-container-low');
                } else {
                    select.disabled = true;
                    content.classList.add('opacity-70');
                    reasonContainer.classList.add('opacity-50', 'pointer-events-none');
                    select.classList.add('bg-surface-container-low');
                    select.value = '';
                }
            }

            item1Check.addEventListener('change', () => toggleItemState(item1Check, reason1Select, item1Container, item1Container.querySelector('.flex-grow'), reason1Select.parentElement));
            item2Check.addEventListener('change', () => toggleItemState(item2Check, reason2Select, item2Container, item2Content, item2ReasonContainer));
        });
    </script>
